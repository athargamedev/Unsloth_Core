{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unsloth-core.local/subjects/schemas/sft_record.schema.json",
  "title": "SFT ChatML JSONL Record",
  "type": "object",
  "required": ["messages", "metadata"],
  "properties": {
    "messages": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": { "type": "string", "enum": ["system", "user", "assistant"] },
          "content": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      },
      "allOf": [
        { "contains": { "type": "object", "properties": { "role": { "const": "user" } }, "required": ["role"] } },
        { "contains": { "type": "object", "properties": { "role": { "const": "assistant" } }, "required": ["role"] } }
      ]
    },
    "metadata": {
      "type": "object",
      "required": [
        "npc_key",
        "technique",
        "split",
        "category",
        "concept",
        "difficulty",
        "source",
        "content_hash",
        "generator_params",
        "safety_tags"
      ],
      "properties": {
        "npc_key": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "technique": { "type": "string", "enum": ["docs", "ollama", "template", "openai", "anthropic"] },
        "split": { "type": "string", "enum": ["train", "validation", "test"] },
        "category": { "type": "string", "enum": ["identity", "teaching", "dialogue", "quest", "refusal"] },
        "concept": { "type": "string", "minLength": 1 },
        "difficulty": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
        "source": { "type": "string", "minLength": 1 },
        "content_hash": { "type": "string", "minLength": 16 },
        "generator_params": {
          "type": "object",
          "additionalProperties": true
        },
        "safety_tags": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
