{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unsloth-core.local/subjects/schemas/sft_record.schema.json",
  "title": "SFT ChatML JSONL Record",
  "type": "object",
  "required": ["messages"],
  "properties": {
    "messages": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": { "type": "string", "enum": ["system", "user", "assistant"] },
          "content": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      },
      "allOf": [
        { "contains": { "type": "object", "properties": { "role": { "const": "user" } }, "required": ["role"] } },
        { "contains": { "type": "object", "properties": { "role": { "const": "assistant" } }, "required": ["role"] } }
      ]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "npc_key": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "technique": { "type": "string", "enum": ["notebooklm", "ollama", "template"] },
        "split": { "type": "string", "enum": ["train", "validation", "test"] },
        "category": { "type": "string" },
        "difficulty": { "type": "string" },
        "source": { "type": "string" },
        "safety_tags": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
