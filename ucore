    eval_p.add_argument("--val-data", help="Validation JSONL path")
    eval_p.add_argument("--num-questions", type=int, default=10, help="Number of eval questions")
    eval_p.add_argument("--output", "-o", help="Output report path")
    eval_p.add_argument("--report-html", action="store_true", help="Generate HTML report with charts")
    eval_p.add_argument("--judge", action="store_true", help="Use local Ollama judge")
    eval_p.add_argument("--judge-model", default="llama3.1:latest", help="Judge model")
    eval_p.add_argument("--track", action="store_true", help="Track results in eval/results/")
    eval_p.add_argument("--wandb", action="store_true", help="Enable W&B evaluation tracking")
    eval_p.add_argument("--wandb-project", default="unsloth-core", help="W&B project (default: unsloth-core)")
    eval_p.add_argument("--interactive", "-i", action="store_true", help="Interactive chat mode")
    eval_p.add_argument("--port", type=int, default=8888, help="llama-server port")
    eval_p.add_argument("--feedback-json", help="Save structured per-concept eval results for the feedback loop")
    eval_p.add_argument("--base-model", help="Base GGUF path (required when --candidate is a LoRA adapter)")
    eval_p.add_argument("--lora-weight", type=float, default=1.0, help="LoRA adapter weight (default: 1.0)")

    # Quick-eval
    qe_p = subparsers.add_parser("quick-eval", help="Quick local evaluation (llama-cpp-python)")
    qe_p.add_argument("adapter_path", help="Path to LoRA adapter or merged GGUF")
    qe_p.add_argument("--samples", "-n", type=int, default=20, help="Number of validation samples")
    qe_p.add_argument("--spec", "-s", help="Subject spec JSON")
    qe_p.add_argument("--val-data", help="Validation JSONL (auto-detected if omitted)")

    # Track
    track_p = subparsers.add_parser("track", help="Track or show evaluation results")
    track_p.add_argument("--npc-key", help="NPC key")
    track_p.add_argument("--model", help="Model GGUF path")
    track_p.add_argument("--show", action="store_true", help="Show evaluation history")
    track_p.add_argument("--win-rate", type=float, help="Win rate vs baseline (0-1)")
    track_p.add_argument("--avg-quality", type=float, help="Average quality score")
    track_p.add_argument("--val-loss", type=float, help="Validation loss")
    track_p.add_argument("--notes", default="", help="Notes about this run")

    # Compare runs
    cr_p = subparsers.add_parser("compare-runs", help="Compare two training runs by run_id")
    cr_p.add_argument("npc_key", help="NPC key")
    cr_p.add_argument("--baseline-run", required=True, help="Baseline run ID")
    cr_p.add_argument("--candidate-run", required=True, help="Candidate run ID")
    cr_p.add_argument("--spec", help="Subject spec (auto-detected if omitted)")
    cr_p.add_argument("--num-questions", type=int, default=10, help="Number of eval questions")
    cr_p.add_argument("--judge", action="store_true", help="Use local Ollama judge")

    # Feedback (Self-Improving Dataset Factory)
    fb_p = subparsers.add_parser("feedback", help="Run the Onyx-powered self-improving feedback loop")
    fb_p.add_argument("feedback_json", help="Path to feedback JSON from evaluate --feedback-json")
    fb_p.add_argument("--win-rate-threshold", type=float, default=0.5, help="Min win rate (default: 0.5)")
    fb_p.add_argument("--quality-threshold", type=float, default=25.0, help="Max quality score, lower=better (default: 25)")
    fb_p.add_argument("--violation-threshold", type=int, default=1, help="Max constraint violations (default: 1)")
    fb_p.add_argument("--dry-run", action="store_true", help="Analyze without regenerating")
    fb_p.add_argument("--auto", "-y", action="store_true", help="Auto-accept all suggestions")
    fb_p.add_argument("--skip-gap-detection", action="store_true",
                       help="Skip Onyx knowledge coverage check")
    fb_p.add_argument("--save-gaps", help="Save knowledge gap report to JSON file")
    fb_p.add_argument("--json", action="store_true",
                       help="Output machine-readable JSON summary")
    fb_p.add_argument("--auto-retrain", action="store_true",
                       help="After regeneration, auto-retrain and re-evaluate")
    fb_p.add_argument("--train-preset", default="fast-3b",
                       help="Training preset for auto-retrain (default: fast-3b)")
    fb_p.add_argument("--baseline", help="Baseline GGUF for auto-evaluation after retrain")

    # Supabase integration check
    sb_p = subparsers.add_parser("supabase-check", help="Verify NPC profile + dialogue memory path in Supabase")
    sb_p.add_argument("--npc-key", required=True, help="NPC key")
    sb_p.add_argument("--player-id", help="Probe player UUID")
    sb_p.add_argument("--skip-probe", action="store_true", help="Only profile alignment, skip dialogue probe")

    # Pipeline (Generate + Sanitize + Train)
    pipe_p = subparsers.add_parser("pipeline", help="Run full generation-to-training pipeline")
    pipe_p.add_argument("spec", help="Path to subject spec JSON")
    pipe_p.add_argument("--preset", default="fast-3b", help="Training preset")
    pipe_p.add_argument("--ollama", action="store_true", help="Shortcut for --technique ollama")
    pipe_p.add_argument("--technique", default="onyx", choices=["docs", "onyx", "ollama", "template", "openai", "anthropic"], help="Generation technique")
    pipe_p.add_argument("--docs-manifest", help="Docs corpus manifest override for --technique docs")
    pipe_p.add_argument("--onyx-url", help="Local Onyx base URL for --technique onyx")
    pipe_p.add_argument("--onyx-api-key", help="Optional Onyx bearer token")
    pipe_p.add_argument("--onyx-max-results", type=int, help="Max Onyx chunks per retrieval query")
    pipe_p.add_argument("--onyx-queries", type=int, help="Number of Onyx retrieval queries per generated example")
    pipe_p.add_argument("--onyx-max-context-chars", type=int, help="Max Onyx context chars per example")
    pipe_p.add_argument("--onyx-document-set", action="append", dest="onyx_document_sets", help="Limit Onyx retrieval to a document set; repeatable")
    pipe_p.add_argument("--onyx-check", action="store_true", help="Check Onyx coverage before generation")
    pipe_p.add_argument("--onyx-min-coverage", type=float, default=None, help="Abort Onyx generation below this coverage ratio")
    pipe_p.add_argument("--onyx-min-score", type=float, default=None, help="Minimum Onyx example quality score; lower-scoring examples are retried/skipped")
    pipe_p.add_argument("--onyx-allow-partial", action="store_true", help="Allow Onyx generation to write fewer examples than requested when quality filtering rejects examples")
    pipe_p.add_argument("--onyx-prep", action="store_true", help="Index targeted subject/repo context before Onyx generation and re-check coverage")
    pipe_p.add_argument("--onyx-prep-passes", type=int, help="Maximum Onyx prep/index/check passes before generation")
    pipe_p.add_argument("--onyx-index-doc", action="append", dest="onyx_index_docs", help="Additional file path or glob to index during --onyx-prep; repeatable")
    pipe_p.add_argument("--onyx-prep-sleep", type=float, help="Seconds to wait after indexing before re-checking coverage")
    pipe_p.add_argument("--onyx-use-llm", action="store_true", help="Use Ollama to rewrite retrieved Onyx context into examples")
    pipe_p.add_argument("--model", help="LLM model name for the generation stage (ollama/openai/anthropic/Onyx LLM rewrite)")
    pipe_p.add_argument("--track", action="store_true", help="Track results in Supabase")
    pipe_p.add_argument("--wandb", action="store_true", help="Enable W&B logging during training")
    pipe_p.add_argument("--full-merge-export", action="store_true",
                        help="Full merge export after training (slower, standalone GGUF)")
    pipe_p.add_argument("--skip-smoke", action="store_true", help="Skip smoke test phase")
    pipe_p.add_argument("--skip-eval", action="store_true", help="Skip evaluation phase")
    pipe_p.add_argument("--num-eval-questions", type=int, default=5,
                        help="Number of evaluation questions (default: 5)")

    # Plan execution placement
    plan_p = subparsers.add_parser("plan-execution", help="Recommend local vs remote (Colab) for generation/training")
    plan_p.add_argument("--spec", required=True, help="Path to subject spec JSON")
    plan_p.add_argument("--preset", help="Training preset")
    plan_p.add_argument("--local-vram-gb", type=float, help="Override detected local VRAM")
    plan_p.add_argument("--json", action="store_true", help="Output JSON")

    # Batch execution planning + optional colab notebook generation
    bp_p = subparsers.add_parser("plan-batch", help="Batch plan local vs remote_colab queues and generate Colab notebooks")
    bp_p.add_argument("--spec-glob", default="subjects/*.json", help="Spec glob under project root")
    bp_p.add_argument("--spec", action="append", dest="specs", help="Explicit spec path (repeatable)")
    bp_p.add_argument("--presets", default="fast-3b", help="Comma-separated presets")
    bp_p.add_argument("--local-vram-gb", type=float, help="Override detected local VRAM")
    bp_p.add_argument("--json", action="store_true", help="Output JSON")
    bp_p.add_argument("--write-plan", help="Write plan JSON to file")
    bp_p.add_argument("--generate-colab-notebooks", action="store_true", help="Generate notebooks for remote_colab queue")
    bp_p.add_argument("--colab-output-dir", default="colab/outputs", help="Notebook output directory")
    bp_p.add_argument("--drive-repo-dir", default="/content/drive/MyDrive/Unsloth_Core", help="Drive path where repo is cloned")

    # Batch export (reuse base model for all NPCs)
    be_p = subparsers.add_parser("batch-export", help="Export all NPCs to GGUF without reloading base model between NPCs")
    be_p.add_argument("--npc", help="Comma-separated NPC keys (default: auto-detect from outputs/)")
    be_p.add_argument("--quantization", default="q4_k_m", help="GGUF quantization (default: q4_k_m)")
    be_p.add_argument("--model", help="Base model ID (auto-detected if omitted)")
    be_p.add_argument("--skip-f16", action="store_true", help="Skip f16 variants")

    # TensorBoard reader
    tb_p = subparsers.add_parser("tb-reader", help="Read TensorBoard event files as JSON")
    tb_p.add_argument("--run-dir", required=True, help="Path to TensorBoard event directory")
    tb_p.add_argument("--indent", type=int, default=2, help="JSON indent (default: 2)")

    # Init/Scaffold
    init_p = subparsers.add_parser("init", aliases=["new-npc"], help="Scaffold a new NPC (folders + spec)")
    init_p.add_argument("npc_key", help="NPC key (snake_case)")
    init_p.add_argument("--subject", help="Subject description")
    init_p.add_argument("--name", help="NPC display name")
    init_p.add_argument("--force", action="store_true", help="Overwrite existing spec")
    init_p.add_argument("--skip-spec", action="store_true", help="Only create folders, skip spec file")

    # Run PeerLM compact eval for a specific NPC
    rpe_p = subparsers.add_parser("run-peerlm-eval", help="Trigger a PeerLM compact eval run for an NPC")
    rpe_p.add_argument("npc_key", help="NPC key (e.g., chef_assistant, history_guide)")
    rpe_p.add_argument("--compact", action="store_true", help="Use compact_suites.json (default behaviour)")
    rpe_p.add_argument("--resources", default="peerlm/compact_suites.json",
                        help="Path to suites resource JSON (default: peerlm/compact_suites.json)")
    rpe_p.add_argument("--estimate-only", action="store_true", help="Estimate credit cost without triggering a run")

    # Audit
    audit_p = subparsers.add_parser("audit", help="Health check and context audit")
    audit_subcmd = audit_p.add_subparsers(dest="audit_command", help="Audit subcommand")
    audit_check = audit_subcmd.add_parser("check", help="Quick environment health check")
    audit_check.add_argument("--full", action="store_true", help="Full audit (env + NPC + datasets + training + eval)")
    audit_diag = audit_subcmd.add_parser("diagnose", help="Diagnose NPC issue")
    audit_diag.add_argument("--npc", required=True, help="NPC key to diagnose")
    audit_subcmd.add_parser("resume", help="Recover session context (full audit)")

    args = parser.parse_args()

    if args.command in ["init", "new-npc"]:
        cmd = [PYTHON, str(SCRIPTS_DIR / "scaffold_npc.py"), args.npc_key]
        if args.subject: cmd.extend(["--subject", args.subject])
        if args.name: cmd.extend(["--name", args.name])
        if args.force: cmd.append("--force")
        if args.skip_spec: cmd.append("--skip-spec")
        run_cmd(cmd)
        sys.exit(0)

    if args.command == "audit":
        from scripts.audit import ProjectAudit
        audit = ProjectAudit()
        if args.audit_command == "check":
            audit.report("full" if args.full else "env")
        elif args.audit_command == "diagnose":
            audit.diagnose_npc(args.npc)
        elif args.audit_command == "resume":
            audit.report("full")
        else:
            audit.report("env")
        sys.exit(0)

    if args.command == "generate":
        cmd = [PYTHON, str(SCRIPTS_DIR / "generate_dataset.py"), args.spec]
        technique = "ollama" if args.ollama else args.technique
        cmd.extend(["--technique", technique])
        if technique == "ollama":
            cmd.append("--ollama")
        if args.docs_manifest:
            cmd.extend(["--docs-manifest", args.docs_manifest])
        if args.onyx_url:
            cmd.extend(["--onyx-url", args.onyx_url])
        if args.onyx_api_key:
