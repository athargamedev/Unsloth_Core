#!/usr/bin/env python3
"""
ucore — Unified Unsloth_Core CLI.

Simplifies the NPC training pipeline:
  generate -> sanitize -> train -> smoke-test
"""

import argparse
import os
import subprocess
import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parent
SCRIPTS_DIR = PROJECT_ROOT / "scripts"
VENV_PYTHON = PROJECT_ROOT / "unsloth_env" / "bin" / "python"
PYTHON = str(VENV_PYTHON) if VENV_PYTHON.exists() else sys.executable

def run_cmd(cmd, cwd=PROJECT_ROOT):
    """Run a shell command and print its output."""
    print(f"Running: {' '.join(cmd)}")
    try:
        subprocess.run(cmd, cwd=str(cwd), check=True)
    except subprocess.CalledProcessError as e:
        print(f"Error: Command failed with return code {e.returncode}")
        sys.exit(e.returncode)

def main():
    parser = argparse.ArgumentParser(description="Unsloth_Core Unified CLI")
    subparsers = parser.add_subparsers(dest="command", help="Command to run")

    # Generate
    gen_p = subparsers.add_parser("generate", help="Generate dataset from spec")
    gen_p.add_argument("spec", help="Path to subject spec JSON")
    gen_p.add_argument("--ollama", action="store_true", help="Shortcut for --technique ollama")
    gen_p.add_argument("--technique", default="notebooklm", choices=["notebooklm", "ollama", "template", "openai", "anthropic"], help="Generation technique")
    gen_p.add_argument("--notebooklm-input", help="NotebookLM export JSON/JSONL path")

    # Sanitize
    san_p = subparsers.add_parser("sanitize", help="Sanitize a dataset")
    san_p.add_argument("input", help="Path to input JSONL")
    san_p.add_argument("--output", "-o", help="Path to output JSONL")
    san_p.add_argument("--strict-canonical", action="store_true", help="Require canonical dataset path")

    # Train
    train_p = subparsers.add_parser("train", help="Train a model")
    train_p.add_argument("config_or_spec", help="Path to config YAML or subject spec")
    train_p.add_argument("--from-spec", action="store_true", help="Train directly from spec")
    train_p.add_argument("--preset", help="Training preset")
    train_p.add_argument("--export-gguf", action="store_true", help="Export to GGUF after training")
    train_p.add_argument("--wandb", action="store_true", default=None,
                         help="Enable W&B logging (overrides config)")

    # Smoke Test
    smoke_p = subparsers.add_parser("smoke", help="Smoke test a GGUF model")
    smoke_p.add_argument("model", help="Path to GGUF model")
    smoke_p.add_argument("--spec", help="Path to subject spec for context")
    smoke_p.add_argument("--check-integrity", action="store_true",
                         help="Validate GGUF file structure (no inference)")
    smoke_p.add_argument("--track", action="store_true", help="Track results in Supabase")

    # Dashboard
    dash_p = subparsers.add_parser("dashboard", help="Start the monitoring dashboard")
    dash_p.add_argument("--port", type=int, default=8000, help="Port")

    # Validate config
    val_p = subparsers.add_parser("validate-config", help="Resolve and validate effective training config")
    val_p.add_argument("--spec", help="Path to subject spec JSON")
    val_p.add_argument("--config", help="Path to YAML config")
    val_p.add_argument("--preset", help="Training preset")
    val_p.add_argument("--data", help="Training data path")
    val_p.add_argument("--model", help="Model ID override")
    val_p.add_argument("--output", help="Output dir override")
    val_p.add_argument("--npc-key", help="npc_key when using --config")
    val_p.add_argument("--format", default="yaml", choices=["yaml", "json"], help="Output format")
    val_p.add_argument("--strict", action="store_true", help="Treat warnings as errors")
    val_p.add_argument("--require-canonical", action="store_true", help="Require canonical dataset train path")

    # Migrate datasets
    mig_p = subparsers.add_parser("migrate-datasets", help="Migrate legacy flat datasets to canonical structure")
    mig_p.add_argument("--apply", action="store_true", help="Apply migration (default dry-run)")
    mig_p.add_argument("--move", action="store_true", help="Move files instead of copy")

    # Export
    export_p = subparsers.add_parser("export", help="Export trained LoRA adapter to GGUF")
    export_p.add_argument("npc_key", help="NPC key (e.g., chemistry_instructor)")
    export_p.add_argument("--model", "-m", help="Base model ID (auto-detected if omitted)")
    export_p.add_argument("--quantization", default="q4_k_m", help="GGUF quantization (default: q4_k_m)")
    export_p.add_argument("--skip-f16", action="store_true", help="Skip exporting f16 variant")

    # Export resume
    exr_p = subparsers.add_parser("export-resume", help="Resume/continue GGUF export for an NPC")
    exr_p.add_argument("npc_key", help="NPC key (e.g., chemistry_instructor)")
    exr_p.add_argument("--model", "-m", help="Base model ID")
    exr_p.add_argument("--quantization", default="q4_k_m", help="GGUF quantization")
    exr_p.add_argument("--skip-f16", action="store_true", help="Skip exporting f16 variant")
    exr_p.add_argument("--timeout-seconds", type=int, default=5400, help="Per-variant timeout")

    # Export adapter (LoRA-only for LLMUnity)
    ea_p = subparsers.add_parser("export-adapter", help="Export LoRA adapter as GGUF (for LLMUnity)")
    ea_p.add_argument("adapter_path", nargs="?", help="Path to PEFT adapter directory")
    ea_p.add_argument("--all", "-a", action="store_true", help="Convert all adapters in outputs/")
    ea_p.add_argument("--outtype", default="f16", choices=["f32", "f16", "bf16", "q8_0", "auto"],
                      help="Output format (default: f16)")
    ea_p.add_argument("--outfile", help="Explicit output file path")

    # Deploy
    deploy_p = subparsers.add_parser("deploy", help="Deploy exports to Unity project")
    deploy_p.add_argument("--unity-project", "-u", help="Path to Unity project (auto-detected if omitted)")
    deploy_p.add_argument("--dry-run", action="store_true", help="Show what would be done without copying")
    deploy_p.add_argument("--skip-export", action="store_true", help="Skip GGUF export step")
    deploy_p.add_argument("--export-only", action="store_true", help="Only export, skip Unity copy")

    # Evaluate
    eval_p = subparsers.add_parser("evaluate", help="Compare two GGUF models side-by-side")
    eval_p.add_argument("--baseline", help="Baseline GGUF model path")
    eval_p.add_argument("--candidate", help="Candidate GGUF model path")
    eval_p.add_argument("--model", "-m", help="Single model GGUF path (for interactive)")
    eval_p.add_argument("--spec", "-s", help="Subject spec JSON")
    eval_p.add_argument("--val-data", help="Validation JSONL path")
    eval_p.add_argument("--num-questions", type=int, default=10, help="Number of eval questions")
    eval_p.add_argument("--output", "-o", help="Output report path")
    eval_p.add_argument("--report-html", action="store_true", help="Generate HTML report with charts")
    eval_p.add_argument("--judge", action="store_true", help="Use local Ollama judge")
    eval_p.add_argument("--judge-model", default="llama3.1:latest", help="Judge model")
    eval_p.add_argument("--track", action="store_true", help="Track results in eval/results/")
    eval_p.add_argument("--wandb", action="store_true", help="Enable W&B evaluation tracking")
    eval_p.add_argument("--wandb-project", default="unsloth-core", help="W&B project (default: unsloth-core)")
    eval_p.add_argument("--interactive", "-i", action="store_true", help="Interactive chat mode")
    eval_p.add_argument("--port", type=int, default=8888, help="llama-server port")

    # Quick-eval
    qe_p = subparsers.add_parser("quick-eval", help="Quick local evaluation (llama-cpp-python)")
    qe_p.add_argument("adapter_path", help="Path to LoRA adapter or merged GGUF")
    qe_p.add_argument("--samples", "-n", type=int, default=20, help="Number of validation samples")
    qe_p.add_argument("--spec", "-s", help="Subject spec JSON")
    qe_p.add_argument("--val-data", help="Validation JSONL (auto-detected if omitted)")

    # Track
    track_p = subparsers.add_parser("track", help="Track or show evaluation results")
    track_p.add_argument("--npc-key", help="NPC key")
    track_p.add_argument("--model", help="Model GGUF path")
    track_p.add_argument("--show", action="store_true", help="Show evaluation history")
    track_p.add_argument("--win-rate", type=float, help="Win rate vs baseline (0-1)")
    track_p.add_argument("--avg-quality", type=float, help="Average quality score")
    track_p.add_argument("--val-loss", type=float, help="Validation loss")
    track_p.add_argument("--notes", default="", help="Notes about this run")

    # Compare runs
    cr_p = subparsers.add_parser("compare-runs", help="Compare two training runs by run_id")
    cr_p.add_argument("npc_key", help="NPC key")
    cr_p.add_argument("--baseline-run", required=True, help="Baseline run ID")
    cr_p.add_argument("--candidate-run", required=True, help="Candidate run ID")
    cr_p.add_argument("--spec", help="Subject spec (auto-detected if omitted)")
    cr_p.add_argument("--num-questions", type=int, default=10, help="Number of eval questions")
    cr_p.add_argument("--judge", action="store_true", help="Use local Ollama judge")

    # Supabase integration check
    sb_p = subparsers.add_parser("supabase-check", help="Verify NPC profile + dialogue memory path in Supabase")
    sb_p.add_argument("--npc-key", required=True, help="NPC key")
    sb_p.add_argument("--player-id", help="Probe player UUID")
    sb_p.add_argument("--skip-probe", action="store_true", help="Only profile alignment, skip dialogue probe")

    # Pipeline (Generate + Sanitize + Train)
    pipe_p = subparsers.add_parser("pipeline", help="Run full generation-to-training pipeline")
    pipe_p.add_argument("spec", help="Path to subject spec JSON")
    pipe_p.add_argument("--preset", default="fast-3b", help="Training preset")
    pipe_p.add_argument("--ollama", action="store_true", help="Shortcut for --technique ollama")
    pipe_p.add_argument("--technique", default="notebooklm", choices=["notebooklm", "ollama", "template", "openai", "anthropic"], help="Generation technique")
    pipe_p.add_argument("--notebooklm-input", help="NotebookLM export JSON/JSONL path")
    pipe_p.add_argument("--track", action="store_true", help="Track results in Supabase")

    args = parser.parse_args()

    if args.command == "generate":
        cmd = [PYTHON, str(SCRIPTS_DIR / "generate_dataset.py"), args.spec]
        technique = "ollama" if args.ollama else args.technique
        cmd.extend(["--technique", technique])
        if technique == "ollama":
            cmd.append("--ollama")
        if args.notebooklm_input:
            cmd.extend(["--notebooklm-input", args.notebooklm_input])
        run_cmd(cmd)

    elif args.command == "sanitize":
        cmd = [PYTHON, str(SCRIPTS_DIR / "sanitize_dataset.py"), args.input]
        if args.output: cmd.extend(["--output", args.output])
        if args.strict_canonical: cmd.append("--strict-canonical")
        run_cmd(cmd)

    elif args.command == "train":
        cmd = [PYTHON, str(SCRIPTS_DIR / "train.py"), args.config_or_spec]
        if args.from_spec: cmd.append("--from-spec")
        if args.preset: cmd.extend(["--preset", args.preset])
        if args.export_gguf: cmd.append("--export-gguf")
        if args.wandb: cmd.append("--wandb")
        run_cmd(cmd)

    elif args.command == "smoke":
        cmd = [PYTHON, str(SCRIPTS_DIR / "smoke_test.py"), args.model]
        if args.spec: cmd.extend(["--spec", args.spec])
        if args.check_integrity: cmd.append("--check-integrity")
        if args.track: cmd.append("--track")
        run_cmd(cmd)

    elif args.command == "dashboard":
        cmd = [PYTHON, str(SCRIPTS_DIR / "dashboard.py"), "--port", str(args.port)]
        run_cmd(cmd)

    elif args.command == "validate-config":
        cmd = [PYTHON, str(SCRIPTS_DIR / "validate_config.py")]
        if args.spec:
            cmd.extend(["--spec", args.spec])
        if args.config:
            cmd.extend(["--config", args.config])
        if args.preset:
            cmd.extend(["--preset", args.preset])
        if args.data:
            cmd.extend(["--data", args.data])
        if args.model:
            cmd.extend(["--model", args.model])
        if args.output:
            cmd.extend(["--output", args.output])
        if args.npc_key:
            cmd.extend(["--npc-key", args.npc_key])
        if args.format:
            cmd.extend(["--format", args.format])
        if args.strict:
            cmd.append("--strict")
        if args.require_canonical:
            cmd.append("--require-canonical")
        run_cmd(cmd)

    elif args.command == "migrate-datasets":
        cmd = [PYTHON, str(SCRIPTS_DIR / "migrate_datasets.py")]
        if args.apply:
            cmd.append("--apply")
        if args.move:
            cmd.append("--move")
        run_cmd(cmd)

    elif args.command == "export":
        cmd = [PYTHON, str(SCRIPTS_DIR / "export.py"), args.npc_key]
        if args.model: cmd.extend(["--model", args.model])
        if args.quantization: cmd.extend(["--quantization", args.quantization])
        if args.skip_f16: cmd.append("--skip-f16")
        run_cmd(cmd)

    elif args.command == "export-resume":
        cmd = [PYTHON, str(SCRIPTS_DIR / "export_resume.py"), args.npc_key]
        if args.model: cmd.extend(["--model", args.model])
        if args.quantization: cmd.extend(["--quantization", args.quantization])
        if args.skip_f16: cmd.append("--skip-f16")
        if args.timeout_seconds: cmd.extend(["--timeout-seconds", str(args.timeout_seconds)])
        run_cmd(cmd)

    elif args.command == "export-adapter":
        cmd = [PYTHON, str(SCRIPTS_DIR / "export_adapter.py")]
        if args.all:
            cmd.append("--all")
        elif args.adapter_path:
            cmd.append(args.adapter_path)
        else:
            print("Error: Provide adapter_path or --all")
            sys.exit(1)
        cmd.extend(["--outtype", args.outtype])
        if args.outfile: cmd.extend(["--outfile", args.outfile])
        run_cmd(cmd)

    elif args.command == "deploy":
        cmd = [PYTHON, str(SCRIPTS_DIR / "deploy_to_unity.py")]
        if args.unity_project: cmd.extend(["--unity-project", args.unity_project])
        if args.dry_run: cmd.append("--dry-run")
        if args.skip_export: cmd.append("--skip-export")
        if args.export_only: cmd.append("--export-only")
        run_cmd(cmd)

    elif args.command == "evaluate":
        cmd = [PYTHON, str(SCRIPTS_DIR / "evaluate.py")]
        if args.baseline: cmd.extend(["--baseline", args.baseline])
        if args.candidate: cmd.extend(["--candidate", args.candidate])
        if args.model: cmd.extend(["--model", args.model])
        if args.spec: cmd.extend(["--spec", args.spec])
        if args.val_data: cmd.extend(["--val-data", args.val_data])
        if args.output: cmd.extend(["--output", args.output])
        if args.report_html: cmd.append("--report-html")
        if args.judge: cmd.append("--judge")
        if args.judge_model: cmd.extend(["--judge-model", args.judge_model])
        if args.track: cmd.append("--track")
        if args.wandb: cmd.append("--wandb")
        if args.wandb_project: cmd.extend(["--wandb-project", args.wandb_project])
        if args.interactive: cmd.append("--interactive")
        if args.port: cmd.extend(["--port", str(args.port)])
        run_cmd(cmd)

    elif args.command == "quick-eval":
        cmd = [PYTHON, str(SCRIPTS_DIR / "quick_eval.py"), args.adapter_path]
        if args.samples: cmd.extend(["--samples", str(args.samples)])
        if args.spec: cmd.extend(["--spec", args.spec])
        if args.val_data: cmd.extend(["--val-data", args.val_data])
        run_cmd(cmd)

    elif args.command == "track":
        if args.show:
            cmd = [PYTHON, str(SCRIPTS_DIR / "track_eval_results.py"), "--show"]
            if args.npc_key: cmd.extend(["--npc-key", args.npc_key])
            run_cmd(cmd)
        else:
            if not args.npc_key:
                print("Error: --npc-key required for tracking (or use --show)")
                sys.exit(1)
            cmd = [PYTHON, str(SCRIPTS_DIR / "track_eval_results.py"), "--track"]
            cmd.extend(["--npc-key", args.npc_key])
            if args.model: cmd.extend(["--model", args.model])
            if args.win_rate: cmd.extend(["--win-rate", str(args.win_rate)])
            if args.avg_quality: cmd.extend(["--avg-quality", str(args.avg_quality)])
            if args.val_loss: cmd.extend(["--val-loss", str(args.val_loss)])
            if args.notes: cmd.extend(["--notes", args.notes])
            run_cmd(cmd)

    elif args.command == "compare-runs":
        cmd = [PYTHON, str(SCRIPTS_DIR / "compare_runs.py"), args.npc_key]
        cmd.extend(["--baseline-run", args.baseline_run])
        cmd.extend(["--candidate-run", args.candidate_run])
        if args.spec: cmd.extend(["--spec", args.spec])
        if args.num_questions: cmd.extend(["--num-questions", str(args.num_questions)])
        if args.judge: cmd.append("--judge")
        run_cmd(cmd)

    elif args.command == "supabase-check":
        cmd = [PYTHON, str(SCRIPTS_DIR / "supabase_integration_check.py"), "--npc-key", args.npc_key]
        if args.player_id: cmd.extend(["--player-id", args.player_id])
        if args.skip_probe: cmd.append("--skip-probe")
        run_cmd(cmd)

    elif args.command == "pipeline":
        print("[STAGE] dataset")
        print(f"--- Phase 1: Generating Dataset ---")
        gen_cmd = [PYTHON, str(SCRIPTS_DIR / "generate_dataset.py"), args.spec]
        technique = "ollama" if args.ollama else args.technique
        gen_cmd.extend(["--technique", technique])
        if technique == "ollama":
            gen_cmd.append("--ollama")
        if args.notebooklm_input:
            gen_cmd.extend(["--notebooklm-input", args.notebooklm_input])
        run_cmd(gen_cmd)

        # Determine paths
        npc_key = Path(args.spec).stem
        dataset_path = f"datasets/{npc_key}/{technique}/train.jsonl"

        print("[STAGE] dataset")
        print(f"\n--- Phase 2: Sanitizing Dataset ---")
        san_path = dataset_path.replace("train.jsonl", "train_clean.jsonl")
        san_cmd = [PYTHON, str(SCRIPTS_DIR / "sanitize_dataset.py"), dataset_path, "--output", san_path, "--strict-canonical"]
        run_cmd(san_cmd)

        print("[STAGE] training")
        print(f"\n--- Phase 3: Training Model ---")
        # Note: train.py --export-gguf will eventually produce a .gguf in exports/{npc_key}/
        train_cmd = [PYTHON, str(SCRIPTS_DIR / "train.py"), args.spec, "--from-spec", "--data", san_path, "--preset", args.preset, "--export-gguf"]
        run_cmd(train_cmd)

        print("[STAGE] export")
        if args.track:
            print("[STAGE] evaluation")
            print(f"\n--- Phase 4: Smoke Testing & Tracking ---")
            # Find the generated GGUF
            export_dir = PROJECT_ROOT / "exports" / npc_key
            ggufs = sorted(export_dir.glob("*.gguf"), key=lambda x: x.stat().st_mtime, reverse=True)
            if ggufs:
                smoke_cmd = [PYTHON, str(SCRIPTS_DIR / "smoke_test.py"), str(ggufs[0]), "--spec", args.spec, "--track"]
                run_cmd(smoke_cmd)
            else:
                print("Warning: No GGUF found for smoke testing")

        print("[STAGE] complete")
        print(f"\n--- Pipeline Complete! ---")

    else:
        parser.print_help()

if __name__ == "__main__":
    main()
