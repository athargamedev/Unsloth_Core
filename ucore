        data = _json.loads(resources_path.read_text())
        items = data.get("resources", [])
        match = [i for i in items if i["npc_key"] == args.npc_key]
        if not match:
            available = [i["npc_key"] for i in items]
            print(f"Error: NPC '{args.npc_key}' not found in {resources_path}.")
