VENV_PYTHON = PROJECT_ROOT / "unsloth_env" / "bin" / "python"
PYTHON = str(VENV_PYTHON) if VENV_PYTHON.exists() else sys.executable

def run_cmd(cmd, cwd=PROJECT_ROOT, announce=True, extra_env=None):
    """Run a shell command and print its output.

    Args:
        cmd: Command list to execute.
        cwd: Working directory.
        announce: Whether to print the command before running.
        extra_env: Optional dict of extra environment variables merged into the current env.
    """
    if announce:
        print(f"Running: {' '.join(cmd)}", flush=True)
    env = os.environ.copy()
    if extra_env:
        env.update(extra_env)
    try:
        subprocess.run(cmd, cwd=str(cwd), check=True, env=env)
    except subprocess.CalledProcessError as e:
        if announce:
            print(f"Error: Command failed with return code {e.returncode}")
        sys.exit(e.returncode)

