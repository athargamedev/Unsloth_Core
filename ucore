    ea_p.add_argument("--outfile", help="Explicit output file path")

    # Deploy
    deploy_p = subparsers.add_parser("deploy", help="Deploy exports to Unity project")
    deploy_p.add_argument("--unity-project", "-u", help="Path to Unity project (auto-detected if omitted)")
    deploy_p.add_argument("--dry-run", action="store_true", help="Show what would be done without copying")
    deploy_p.add_argument("--skip-export", action="store_true", help="Skip GGUF export step")
    deploy_p.add_argument("--export-only", action="store_true", help="Only export, skip Unity copy")

    # Evaluate
    eval_p = subparsers.add_parser("evaluate", help="Compare two GGUF models side-by-side")
    eval_p.add_argument("--baseline", help="Baseline GGUF model path")
    eval_p.add_argument("--candidate", help="Candidate GGUF model path")
    eval_p.add_argument("--model", "-m", help="Single model GGUF path (for interactive)")
